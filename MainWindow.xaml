                                    <CheckBox x:Name="RefreshServicesAfterActionCheckBox" Content="Refresh services after service actions" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Bahnschrift" FontSize="15" Margin="0,0,0,14" Checked="SettingsControl_OnChanged" Unchecked="SettingsControl_OnChanged" />
                                    <CheckBox x:Name="EnableLeftAltShortcutCheckBox" Content="Use Left Alt to hide and show the app" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Bahnschrift" FontSize="15" Margin="0,0,0,14" Checked="SettingsControl_OnChanged" Unchecked="SettingsControl_OnChanged" />
                                    <CheckBox x:Name="AutoRefreshRunningAppsCheckBox" Content="Refresh running apps when the tab opens" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Bahnschrift" FontSize="15" Margin="0,0,0,14" Checked="SettingsControl_OnChanged" Unchecked="SettingsControl_OnChanged" />
                                    <CheckBox x:Name="RememberAiHistoryCheckBox" Content="Let Wes AI remember this session while the app is open" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Bahnschrift" FontSize="15" Margin="0,0,0,14" Checked="SettingsControl_OnChanged" Unchecked="SettingsControl_OnChanged" />
                                    <CheckBox x:Name="ShowAppPathsCheckBox" Content="Show full executable paths in the library" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Bahnschrift" FontSize="15" Margin="0,0,0,14" Checked="SettingsControl_OnChanged" Unchecked="SettingsControl_OnChanged" />
                                    <CheckBox x:Name="SendAiOnEnterCheckBox" Content="Send Wes AI messages when you press Enter" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Bahnschrift" FontSize="15" Margin="0,0,0,14" Checked="SettingsControl_OnChanged" Unchecked="SettingsControl_OnChanged" />
                                    <CheckBox x:Name="StartSystemMonitorLiveCheckBox" Content="Keep System Monitor updating live while its tab is open" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Bahnschrift" FontSize="15" Margin="0,0,0,14" Checked="SettingsControl_OnChanged" Unchecked="SettingsControl_OnChanged" />
                                    <CheckBox x:Name="OpenCaptureFolderAfterScreenshotCheckBox" Content="Open the captures folder after taking a screenshot" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Bahnschrift" FontSize="15" Margin="0,0,0,14" Checked="SettingsControl_OnChanged" Unchecked="SettingsControl_OnChanged" />
                                    <CheckBox x:Name="StartConsoleWhenOpenedCheckBox" Content="Start the console automatically when its tab opens" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Bahnschrift" FontSize="15" Checked="SettingsControl_OnChanged" Unchecked="SettingsControl_OnChanged" />
                                </StackPanel>
                            </Border>
                            <Border Background="{DynamicResource PanelBrush}" CornerRadius="22" Padding="18" Margin="0,0,0,18">
                                <StackPanel>
                                    <TextBlock Text="Animations" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Bahnschrift SemiBold" FontSize="20" />
                                    <Grid Margin="0,18,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="PreviousInterfaceAnimationButton" Click="PreviousInterfaceAnimationButton_OnClick" Style="{StaticResource SecondaryButtonStyle}" Content="&lt;" Width="54" />
                                        <StackPanel Grid.Column="1" Margin="16,0">
                                            <TextBlock Text="Inside App Animation Mode" Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Bahnschrift SemiBold" FontSize="13" />
                                            <TextBlock x:Name="InterfaceAnimationModeTextBlock" Margin="0,8,0,0" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Bahnschrift SemiBold" FontSize="20" />
                                        </StackPanel>
                                        <Button Grid.Column="2" x:Name="NextInterfaceAnimationButton" Click="NextInterfaceAnimationButton_OnClick" Style="{StaticResource SecondaryButtonStyle}" Content="&gt;" Width="54" />
                                    </Grid>
                                    <Grid Margin="0,18,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="PreviousAltAnimationButton" Click="PreviousAltAnimationButton_OnClick" Style="{StaticResource SecondaryButtonStyle}" Content="&lt;" Width="54" />
                                        <StackPanel Grid.Column="1" Margin="16,0">
                                            <TextBlock Text="Left Alt Hide/Show Animation" Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Bahnschrift SemiBold" FontSize="13" />
                                            <TextBlock x:Name="AltAnimationModeTextBlock" Margin="0,8,0,0" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Bahnschrift SemiBold" FontSize="20" />
                                        </StackPanel>
                                        <Button Grid.Column="2" x:Name="NextAltAnimationButton" Click="NextAltAnimationButton_OnClick" Style="{StaticResource SecondaryButtonStyle}" Content="&gt;" Width="54" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                            <Border Background="{DynamicResource PanelBrush}" CornerRadius="22" Padding="18">
                                <StackPanel>
                                    <TextBlock Text="Wes AI" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Bahnschrift SemiBold" FontSize="20" />
                                    <TextBlock Margin="0,10,0,0" Text="Add your OpenAI API key and choose the chat model Wes should use. This stays local in your Wes's Tools settings file." Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Bahnschrift" FontSize="13" TextWrapping="Wrap" />
                                    <TextBlock Margin="0,18,0,6" Text="OpenAI API Key" Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Bahnschrift SemiBold" FontSize="12" />
                                    <PasswordBox x:Name="OpenAiApiKeyPasswordBox" PasswordChanged="OpenAiApiKeyPasswordBox_OnPasswordChanged" Foreground="{DynamicResource TextPrimaryBrush}" Background="#221A2744" BorderBrush="#3356709E" BorderThickness="1" FontFamily="Consolas" FontSize="13" Padding="14,10" />
                                    <TextBlock Margin="0,16,0,6" Text="Model" Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Bahnschrift SemiBold" FontSize="12" />
                                    <TextBox x:Name="OpenAiModelTextBox" Style="{StaticResource SearchBoxStyle}" TextChanged="OpenAiModelTextBox_OnTextChanged" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>
    </Grid>

        <Grid x:Name="StartupOverlay" Panel.ZIndex="50" Background="{DynamicResource BackgroundBrush}" Opacity="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <Ellipse Width="520" Height="520" Fill="#1A27C6F8" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-150,-120,0" IsHitTestVisible="False" />
                <Ellipse Width="420" Height="420" Fill="#16FF7A45" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-120,0,0,-140" IsHitTestVisible="False" />

                <Border x:Name="StartupCard" Width="760" MaxWidth="760" Padding="44" CornerRadius="34" Background="#2216233C" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <TransformGroup>
                            <TranslateTransform Y="38" />
                            <ScaleTransform ScaleX="0.98" ScaleY="0.98" />
                        </TransformGroup>
                    </Border.RenderTransform>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="38" ShadowDepth="0" Color="#66000000" />
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel x:Name="StartupHeaderPanel" HorizontalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                            <StackPanel.RenderTransform>
                                <TranslateTransform Y="26" />
                            </StackPanel.RenderTransform>
                            <Border Width="112" Height="112" CornerRadius="34" Background="#26000000" HorizontalAlignment="Center">
                                <Image x:Name="StartupLogoImage" Width="76" Height="76" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                    <Image.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform ScaleX="0.86" ScaleY="0.86" />
                                            <TranslateTransform Y="10" />
                                        </TransformGroup>
                                    </Image.RenderTransform>
                                </Image>
                            </Border>
                            <TextBlock x:Name="StartupTitleTextBlock" Margin="0,22,0,0" Text="Wes's Tools" HorizontalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Bahnschrift SemiBold" FontSize="42" Opacity="0.2" />
                            <TextBlock x:Name="StartupSubtitleTextBlock" Margin="0,10,0,0" Text="A fast launcher deck for apps, tools, monitoring, capture, and Wes AI." HorizontalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Bahnschrift" FontSize="16" TextWrapping="Wrap" TextAlignment="Center" Opacity="0.2" />
                        </StackPanel>

                        <Border x:Name="StartupLoadingPanel" Grid.Row="1" Margin="0,30,0,0" Background="#1B000000" CornerRadius="24" Padding="24" Opacity="0.15" RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <TranslateTransform Y="24" />
                            </Border.RenderTransform>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Launching Deck" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Bahnschrift SemiBold" FontSize="18" />
                                    <TextBlock x:Name="StartupStageTextBlock" Margin="0,8,0,0" Text="Loading assets" Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Bahnschrift" FontSize="14" />
                                </StackPanel>
                                <TextBlock Grid.Column="1" x:Name="StartupPercentTextBlock" Text="0%" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Bahnschrift SemiBold" FontSize="18" VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <StackPanel x:Name="StartupProgressPanel" Grid.Row="2" Margin="0,24,0,0" Opacity="0.15" RenderTransformOrigin="0.5,0.5">
                            <StackPanel.RenderTransform>
                                <TranslateTransform Y="24" />
                            </StackPanel.RenderTransform>
                            <Border Height="12" CornerRadius="999" Background="#22000000">
                                <Border x:Name="StartupProgressBar" Background="{DynamicResource AccentBrush}" CornerRadius="999" HorizontalAlignment="Stretch" RenderTransformOrigin="0,0.5">
                                    <Border.RenderTransform>
                                        <ScaleTransform ScaleX="0" />
                                    </Border.RenderTransform>
                                </Border>
                            </Border>
                            <TextBlock Margin="0,10,0,0" Text="Fast startup mode keeps the intro short while the full tool deck finishes syncing in the background." Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Bahnschrift" FontSize="13" TextWrapping="Wrap" TextAlignment="Center" />
                        </StackPanel>

                        <Border x:Name="StartupCreditsPanel" Grid.Row="3" Margin="0,26,0,0" Background="#16000000" CornerRadius="22" Padding="22" Opacity="0.15" RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <TranslateTransform Y="28" />
                            </Border.RenderTransform>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Credits" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Bahnschrift SemiBold" FontSize="16" />
                                    <TextBlock Margin="0,12,0,0" Text="Charlis350" Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Bahnschrift" FontSize="14" />
                                    <TextBlock Margin="0,6,0,0" Text="WalkerGoat52" Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Bahnschrift" FontSize="14" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Built For" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Bahnschrift SemiBold" FontSize="16" />
                                    <TextBlock Margin="0,12,0,0" Text="Wes's launcher deck vision" Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Bahnschrift" FontSize="14" />
                                    <TextBlock Margin="0,6,0,0" Text="Smooth startup and premium tool UI pass" Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Bahnschrift" FontSize="14" TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <TextBlock Grid.Row="1" Margin="0,0,0,28" Text="Wes's Tools is getting your deck ready" HorizontalAlignment="Center" Foreground="#88FFFFFF" FontFamily="Bahnschrift" FontSize="13" />
        </Grid>
    </Grid>
</Window>
