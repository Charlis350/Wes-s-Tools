<Window x:Class="WessTools.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:WessTools.Models"
        mc:Ignorable="d"
        Title="Wes's Tools"
        Width="1480"
        Height="920"
        MinWidth="1180"
        MinHeight="780"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}"
        Loaded="Window_OnLoaded">
    <Grid>
    <Grid x:Name="RootShell" RenderTransformOrigin="0.5,0.5" Opacity="0">
        <Grid.RenderTransform>
            <ScaleTransform ScaleX="1" ScaleY="1" />
        </Grid.RenderTransform>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="270" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border x:Name="SidebarPanel" Grid.Column="0" Background="{DynamicResource SidebarBrush}" Padding="20">
            <Border.RenderTransform>
                <TranslateTransform X="-30" />
            </Border.RenderTransform>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <Border Width="78" Height="78" CornerRadius="24" Background="#18000000" HorizontalAlignment="Left">
                        <Image x:Name="BrandIconImage" Width="54" Height="54" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Margin="0,16,0,0" Text="Wes's Tools" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Bahnschrift SemiBold" FontSize="28" />
                    <TextBlock Margin="0,4,0,0" Text="Performance deck" Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Bahnschrift" FontSize="13" />
                    <TextBlock Margin="0,14,0,0" Text="Launch apps, inspect running windows, chat with Wes AI, and use quick system tools from one clean deck." Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Bahnschrift" FontSize="14" TextWrapping="Wrap" />
                </StackPanel>

                <ScrollViewer x:Name="SidebarTabsScrollViewer" Grid.Row="1" Margin="0,28,0,20" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" CanContentScroll="True" PreviewMouseWheel="SidebarTabsScrollViewer_OnPreviewMouseWheel">
                <StackPanel>
                    <Button x:Name="LibraryTabButton" Click="LibraryTabButton_OnClick" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8D4;" FontFamily="Segoe Fluent Icons" />
                            <TextBlock Text="Library" Margin="10,0,0,0" FontFamily="Bahnschrift SemiBold" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="RunningAppsTabButton" Click="RunningAppsTabButton_OnClick" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7F4;" FontFamily="Segoe Fluent Icons" />
                            <TextBlock Text="Running Apps" Margin="10,0,0,0" FontFamily="Bahnschrift SemiBold" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="OptimizationTabButton" Click="OptimizationTabButton_OnClick" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE9D9;" FontFamily="Segoe Fluent Icons" />
                            <TextBlock Text="Optimization" Margin="10,0,0,0" FontFamily="Bahnschrift SemiBold" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="ServicesTabButton" Click="ServicesTabButton_OnClick" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE945;" FontFamily="Segoe Fluent Icons" />
                            <TextBlock Text="Services" Margin="10,0,0,0" FontFamily="Bahnschrift SemiBold" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="StartupAppsTabButton" Click="StartupAppsTabButton_OnClick" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7F1;" FontFamily="Segoe Fluent Icons" />
                            <TextBlock Text="Startup Apps" Margin="10,0,0,0" FontFamily="Bahnschrift SemiBold" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="NetworkToolsTabButton" Click="NetworkToolsTabButton_OnClick" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE968;" FontFamily="Segoe Fluent Icons" />
                            <TextBlock Text="Network Tools" Margin="10,0,0,0" FontFamily="Bahnschrift SemiBold" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="GameProfilesTabButton" Click="GameProfilesTabButton_OnClick" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7FC;" FontFamily="Segoe Fluent Icons" />
                            <TextBlock Text="Game Profiles" Margin="10,0,0,0" FontFamily="Bahnschrift SemiBold" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="SystemMonitorTabButton" Click="SystemMonitorTabButton_OnClick" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE9D2;" FontFamily="Segoe Fluent Icons" />
                            <TextBlock Text="System Monitor" Margin="10,0,0,0" FontFamily="Bahnschrift SemiBold" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="CaptureHubTabButton" Click="CaptureHubTabButton_OnClick" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE722;" FontFamily="Segoe Fluent Icons" />
                            <TextBlock Text="Capture Hub" Margin="10,0,0,0" FontFamily="Bahnschrift SemiBold" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="ConsoleTabButton" Click="ConsoleTabButton_OnClick" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE756;" FontFamily="Segoe Fluent Icons" />
                            <TextBlock Text="Console" Margin="10,0,0,0" FontFamily="Bahnschrift SemiBold" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="RepairToolsTabButton" Click="RepairToolsTabButton_OnClick" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE90F;" FontFamily="Segoe Fluent Icons" />
                            <TextBlock Text="Repair Tools" Margin="10,0,0,0" FontFamily="Bahnschrift SemiBold" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="FileToolsTabButton" Click="FileToolsTabButton_OnClick" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8B7;" FontFamily="Segoe Fluent Icons" />
                            <TextBlock Text="File Tools" Margin="10,0,0,0" FontFamily="Bahnschrift SemiBold" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="WesAiTabButton" Click="WesAiTabButton_OnClick" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE9CE;" FontFamily="Segoe Fluent Icons" />
                            <TextBlock Text="Wes AI" Margin="10,0,0,0" FontFamily="Bahnschrift SemiBold" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="SettingsTabButton" Click="SettingsTabButton_OnClick" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE713;" FontFamily="Segoe Fluent Icons" />
                            <TextBlock Text="Settings" Margin="10,0,0,0" FontFamily="Bahnschrift SemiBold" />
                        </StackPanel>
                    </Button>
                    <Button Click="RefreshAllButton_OnClick" Style="{StaticResource SecondaryButtonStyle}" Content="Refresh Everything" />
                </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2" Background="{DynamicResource PanelBrush}" CornerRadius="20" Padding="16" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="Status" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Bahnschrift SemiBold" FontSize="18" />
                        <TextBlock x:Name="StatusTextBlock" Margin="0,10,0,0" Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Bahnschrift" FontSize="14" TextWrapping="Wrap" />
                        <TextBlock Text="Verified Apps" Margin="0,16,0,0" Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Bahnschrift SemiBold" FontSize="12" />
                        <TextBlock x:Name="AppCountTextBlock" Margin="0,4,0,0" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Bahnschrift SemiBold" FontSize="15" />
                        <TextBlock Text="Running Apps" Margin="0,10,0,0" Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Bahnschrift SemiBold" FontSize="12" />
                        <TextBlock x:Name="RunningAppCountTextBlock" Margin="0,4,0,0" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Bahnschrift SemiBold" FontSize="15" />
                        <TextBlock Text="Services" Margin="0,10,0,0" Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Bahnschrift SemiBold" FontSize="12" />
                        <TextBlock x:Name="ServiceCountTextBlock" Margin="0,4,0,0" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Bahnschrift SemiBold" FontSize="15" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="3" Background="{DynamicResource PanelBrush}" CornerRadius="18" Padding="16">
                    <TextBlock Text="Press Left Alt by itself to hide or show Wes's Tools with a quick pop animation." Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Bahnschrift" FontSize="13" TextWrapping="Wrap" />
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border x:Name="HeroPanel" Background="{DynamicResource HeroBrush}" CornerRadius="28" Padding="28" Margin="0,0,0,18">
                <Border.RenderTransform>
                    <TranslateTransform Y="22" />
                </Border.RenderTransform>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="360" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock x:Name="HeroTitleTextBlock" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Bahnschrift SemiBold" FontSize="36" TextWrapping="Wrap" />
                        <TextBlock x:Name="HeroSubtitleTextBlock" Margin="0,10,0,0" Foreground="#FFE5EEFF" FontFamily="Bahnschrift" FontSize="16" TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                            <Button x:Name="HeroPrimaryButton" Click="HeroPrimaryButton_OnClick" Style="{StaticResource PrimaryButtonStyle}" Content="Refresh" />
                            <Button x:Name="HeroSecondaryButton" Click="HeroSecondaryButton_OnClick" Style="{StaticResource SecondaryButtonStyle}" Content="Next" Margin="12,0,0,0" />
                        </StackPanel>
                    </StackPanel>
                    <Border Grid.Column="1" Background="#220B1020" CornerRadius="22" Padding="18">
                        <StackPanel>
                            <TextBlock Text="Deck Stats" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Bahnschrift SemiBold" FontSize="20" />
                            <TextBlock Text="Verified Apps" Margin="0,16,0,0" Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Bahnschrift SemiBold" FontSize="12" />
                            <TextBlock x:Name="HeroAppsTextBlock" Margin="0,4,0,0" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Bahnschrift SemiBold" FontSize="24" />
                            <TextBlock Text="Games Found" Margin="0,12,0,0" Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Bahnschrift SemiBold" FontSize="12" />
                            <TextBlock x:Name="HeroGamesTextBlock" Margin="0,4,0,0" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Bahnschrift SemiBold" FontSize="24" />
                            <TextBlock Text="Running Apps" Margin="0,12,0,0" Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Bahnschrift SemiBold" FontSize="12" />
                            <TextBlock x:Name="HeroRunningAppsTextBlock" Margin="0,4,0,0" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Bahnschrift SemiBold" FontSize="24" />
                            <TextBlock Text="Services Indexed" Margin="0,12,0,0" Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Bahnschrift SemiBold" FontSize="12" />
                            <TextBlock x:Name="HeroServicesTextBlock" Margin="0,4,0,0" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Bahnschrift SemiBold" FontSize="24" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid x:Name="LibraryView">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="AppSearchTextBox" Style="{StaticResource SearchBoxStyle}" TextChanged="AppSearchTextBox_OnTextChanged" />
                        <Button Grid.Column="1" Click="RefreshAppsButton_OnClick" Style="{StaticResource SecondaryButtonStyle}" Content="Refresh Library" Margin="12,0,0,0" />
                    </Grid>
                    <ItemsControl x:Name="FeaturedGamesItemsControl" Grid.Row="1" Margin="0,0,0,16">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:LaunchableApp}">
                                <Border Width="230" Margin="0,0,14,0" Padding="16" CornerRadius="20" Background="{DynamicResource PanelAltBrush}">
                                    <StackPanel>
                                        <Grid Width="52" Height="52">
                                            <Border CornerRadius="16" Background="#2627C6F8" />
                                            <TextBlock Text="{Binding TileGlyph}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Bahnschrift SemiBold" FontSize="22" />
                                            <Image Source="{Binding IconSource}" Width="38" Height="38" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Grid>
                                        <TextBlock Margin="0,14,0,0" Text="{Binding Name}" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Bahnschrift SemiBold" FontSize="17" TextWrapping="Wrap" />
                                        <TextBlock Margin="0,8,0,0" Text="{Binding SourceLabel}" Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Bahnschrift" FontSize="12" TextWrapping="Wrap" MaxHeight="36" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Border Grid.Row="2" Background="{DynamicResource PanelBrush}" CornerRadius="22" Padding="14">
                        <ListView x:Name="AppsListView" BorderThickness="0" Background="Transparent">
                            <ListView.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:LaunchableApp}">
                                    <Border Background="{DynamicResource PanelAltBrush}" CornerRadius="18" Padding="14" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Grid Width="52" Height="52">
                                                <Border CornerRadius="16" Background="#2627C6F8" />
                                                <TextBlock Text="{Binding TileGlyph}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Bahnschrift SemiBold" FontSize="20" />
                                                <Image Source="{Binding IconSource}" Width="38" Height="38" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Grid>
                                            <StackPanel Grid.Column="1" Margin="14,0,14,0">
                                                <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Bahnschrift SemiBold" FontSize="17" TextWrapping="Wrap" />
                                                <TextBlock Margin="0,6,0,0" Text="{Binding Subtitle}" Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Bahnschrift" FontSize="12" TextWrapping="Wrap" MaxHeight="40" />
                                                <TextBlock Margin="0,6,0,0" Text="{Binding ExecutablePath}" Foreground="#FF7390C2" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap" MaxHeight="34" Visibility="{Binding DataContext.AppPathVisibility, RelativeSource={RelativeSource AncestorType=Window}}" />
                                            </StackPanel>
                                            <Button Grid.Column="2" Click="LaunchAppButton_OnClick" Style="{StaticResource PrimaryButtonStyle}" Content="Launch" Tag="{Binding}" VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Border>
                </Grid>
                <Grid x:Name="RunningAppsView" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="RunningAppsSearchTextBox" Style="{StaticResource SearchBoxStyle}" TextChanged="RunningAppsSearchTextBox_OnTextChanged" />
                        <Button Grid.Column="1" Click="RefreshRunningAppsButton_OnClick" Style="{StaticResource SecondaryButtonStyle}" Content="Refresh Running Apps" Margin="12,0,0,0" />
                    </Grid>
                    <Border Grid.Row="1" Background="{DynamicResource PanelBrush}" CornerRadius="22" Padding="14">
                        <ListView x:Name="RunningAppsListView" BorderThickness="0" Background="Transparent">
                            <ListView.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:RunningAppEntry}">
                                    <Border Background="{DynamicResource PanelAltBrush}" CornerRadius="18" Padding="14" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Grid Width="52" Height="52">
                                                <Border CornerRadius="16" Background="#2627C6F8" />
                                                <TextBlock Text="{Binding TileGlyph}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Bahnschrift SemiBold" FontSize="20" />
                                                <Image Source="{Binding IconSource}" Width="38" Height="38" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Grid>
                                            <StackPanel Grid.Column="1" Margin="14,0,14,0">
                                                <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Bahnschrift SemiBold" FontSize="17" TextWrapping="Wrap" />
                                                <TextBlock Margin="0,6,0,0" Text="{Binding WindowTitle}" Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Bahnschrift" FontSize="12" TextWrapping="Wrap" MaxHeight="34" />
                                                <TextBlock Margin="0,6,0,0" Text="{Binding MemoryText}" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Bahnschrift SemiBold" FontSize="12" />
                                            </StackPanel>
                                            <Button Grid.Column="2" Click="CloseRunningAppButton_OnClick" Style="{StaticResource SecondaryButtonStyle}" Content="Close App" Tag="{Binding}" VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Border>
                </Grid>
                <Grid x:Name="OptimizationView" Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <UniformGrid Columns="2">
                            <Border Background="{DynamicResource PanelBrush}" CornerRadius="22" Padding="18" Margin="0,0,12,12">
                                <StackPanel>
                                    <TextBlock Text="FPS Boost" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Bahnschrift SemiBold" FontSize="20" />
                                    <TextBlock Margin="0,10,0,0" Text="Switch Windows to the High Performance power plan." Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Bahnschrift" FontSize="13" TextWrapping="Wrap" />
                                    <Button Margin="0,16,0,0" Click="HighPerformanceButton_OnClick" Style="{StaticResource PrimaryButtonStyle}" Content="Enable High Performance" />
                                </StackPanel>
                            </Border>
                            <Border Background="{DynamicResource PanelBrush}" CornerRadius="22" Padding="18" Margin="12,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Ping Refresh" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Bahnschrift SemiBold" FontSize="20" />
                                    <TextBlock Margin="0,10,0,0" Text="Flush DNS so stale network name lookups are cleared." Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Bahnschrift" FontSize="13" TextWrapping="Wrap" />
                                    <Button Margin="0,16,0,0" Click="FlushDnsButton_OnClick" Style="{StaticResource PrimaryButtonStyle}" Content="Flush DNS Cache" />
                                </StackPanel>
                            </Border>
                            <Border Background="{DynamicResource PanelBrush}" CornerRadius="22" Padding="18" Margin="0,12,12,0">
                                <StackPanel>
                                    <TextBlock Text="Temp Cleanup" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Bahnschrift SemiBold" FontSize="20" />
                                    <TextBlock Margin="0,10,0,0" Text="Clear temp-file clutter that can slow game launchers and tools." Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Bahnschrift" FontSize="13" TextWrapping="Wrap" />
                                    <Button Margin="0,16,0,0" Click="CleanTempButton_OnClick" Style="{StaticResource PrimaryButtonStyle}" Content="Clean Temp Files" />
                                </StackPanel>
                            </Border>
                            <Border Background="{DynamicResource PanelBrush}" CornerRadius="22" Padding="18" Margin="12,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="Game Mode" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Bahnschrift SemiBold" FontSize="20" />
                                    <TextBlock Margin="0,10,0,0" Text="Jump straight to Windows Game Mode settings." Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Bahnschrift" FontSize="13" TextWrapping="Wrap" />
                                    <Button Margin="0,16,0,0" Click="GameModeButton_OnClick" Style="{StaticResource PrimaryButtonStyle}" Content="Open Game Mode" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </ScrollViewer>
                </Grid>
                <Grid x:Name="ServicesView" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="ServiceSearchTextBox" Style="{StaticResource SearchBoxStyle}" TextChanged="ServiceSearchTextBox_OnTextChanged" />
                        <Button Grid.Column="1" Click="RefreshServicesButton_OnClick" Style="{StaticResource SecondaryButtonStyle}" Content="Refresh Services" Margin="12,0,0,0" />
                    </Grid>
                    <Border Grid.Row="1" Background="{DynamicResource PanelBrush}" CornerRadius="22" Padding="14">
                        <ListView x:Name="ServicesListView" BorderThickness="0" Background="Transparent">
                            <ListView.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:ServiceEntry}">
                                    <Border Background="{DynamicResource PanelAltBrush}" CornerRadius="18" Padding="14" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*" />
                                                <ColumnDefinition Width="1*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Bahnschrift SemiBold" FontSize="16" />
                                                <TextBlock Margin="0,6,0,0" Text="{Binding Description}" Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Bahnschrift" FontSize="12" TextWrapping="Wrap" MaxHeight="40" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Margin="16,0,16,0">
                                                <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Bahnschrift SemiBold" FontSize="15" />
                                                <TextBlock Margin="0,6,0,0" Text="{Binding StartMode}" Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Bahnschrift" FontSize="12" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button Click="StartServiceButton_OnClick" Style="{StaticResource SecondaryButtonStyle}" Content="Start" Margin="0,0,8,0" Tag="{Binding}" IsEnabled="{Binding CanStart}" />
                                                <Button Click="StopServiceButton_OnClick" Style="{StaticResource SecondaryButtonStyle}" Content="Stop" Margin="0,0,8,0" Tag="{Binding}" IsEnabled="{Binding CanStop}" />
                                                <Button Click="RestartServiceButton_OnClick" Style="{StaticResource PrimaryButtonStyle}" Content="Restart" Tag="{Binding}" IsEnabled="{Binding CanRestart}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Border>
                </Grid>
                <Grid x:Name="StartupAppsView" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="StartupSearchTextBox" Style="{StaticResource SearchBoxStyle}" TextChanged="StartupSearchTextBox_OnTextChanged" />
                        <Button Grid.Column="1" Click="RefreshStartupAppsButton_OnClick" Style="{StaticResource SecondaryButtonStyle}" Content="Refresh Startup Apps" Margin="12,0,0,0" />
                    </Grid>
                    <Border Grid.Row="1" Background="{DynamicResource PanelBrush}" CornerRadius="22" Padding="14">
                        <ListView x:Name="StartupAppsListView" BorderThickness="0" Background="Transparent">
                            <ListView.ItemTemplate>
